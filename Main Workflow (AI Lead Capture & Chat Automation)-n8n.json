        "jsCode": "// Get the output text from the AI Agent\nconst aiResponse = $input.first().json.output;\n\ntry {\n  // 1. Clean up the text (remove ```json and ``` markers if present)\n  const cleanText = aiResponse.replace(/```json/g, '').replace(/```/g, '').trim();\n\n  // 2. Parse the text into a real JSON object\n  const contactData = JSON.parse(cleanText);\n\n  // 3. Return the clean data\n  return contactData;\n\n} catch (error) {\n  // If something goes wrong, return nulls so the workflow doesn't stop\n  return {\n    name: null,\n    email: null,\n    phone: null\n  };\n}"
      },
